# Copia este archivo a .env.local y completa con los valores de tu proyecto Supabase
# (Dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY

# Server-only (NO usar prefijo NEXT_PUBLIC_): necesarias para /api/send-comment-email
# Dashboard -> Project Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY
# API key de Resend (https://resend.com/api-keys); el dominio del "from" debe estar verificado
RESEND_API_KEY=TU_RESEND_API_KEY
