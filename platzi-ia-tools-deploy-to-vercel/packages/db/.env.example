# Connection string de Postgres (Supabase)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Copia este archivo a .env.local y rellena el valor real.
# Nunca commitees .env ni .env.local — están gitignored.
# Url-encodea caracteres especiales en el password ('$' → %24, '*' → %2A, etc.).
DATABASE_URL=postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-1-region.pooler.supabase.com:5432/postgres
