# Copia este archivo a .env.local y rellena con valores reales.

# Supabase - Postgres connection string (pooler, modo transaction).
# Url-encodea caracteres especiales en el password ('$' → %24, '*' → %2A, etc.).
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-1-region.pooler.supabase.com:5432/postgres

# Base URL del sitio. En dev usa http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
